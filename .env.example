# ─────────────────────────────────────────
#  Morning Briefing Bot — Environment Setup
# ─────────────────────────────────────────
# Copy this file to .env and fill in your keys

# 🌤 Weather (free): https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_key_here
WEATHER_CITY=Coimbatore

# 📰 News (free): https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# 🤖 Telegram Bot
# 1. Message @BotFather on Telegram → /newbot
# 2. Paste the token below
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 3. Message @userinfobot on Telegram to get your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# 🧠 Groq AI (free, super fast): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ⏰ Schedule (24hr format)
BRIEFING_TIME=07:00

# 🌍 Country code for news (in = India)
NEWS_COUNTRY=in

# 📂 Optional: tasks file path
TASKS_FILE=tasks.txt
